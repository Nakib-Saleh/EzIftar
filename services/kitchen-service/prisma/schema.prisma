generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KitchenOrder {
  id          String   @id @default(uuid())
  orderId     String   @unique
  itemId      String
  quantity    Int
  studentId   String
  studentName String
  status      String   @default("PENDING") // PENDING, STOCK_VERIFIED, IN_KITCHEN, READY, FAILED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
